generator client {
  provider        = "prisma-client"
}

datasource db {
  provider = "postgresql"
  
}

model Session {
  id        String    @id
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@map("sessions")
}

model Message {
  id        String   @id
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}
